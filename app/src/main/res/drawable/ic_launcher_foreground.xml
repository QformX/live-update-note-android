<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="100"
    android:viewportHeight="100">
    <!-- Scaled group to keep the logo inside the Adaptive Icon safe zone (0.72) -->
    <group
        android:pivotX="50"
        android:pivotY="50"
        android:scaleX="0.72"
        android:scaleY="0.72">
        
        <!-- Thin outer circle outline of the moon -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#80FFFFFF"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:pathData="M 50,10 A 40,40 0 1,1 49.9,10 Z" />
            
        <!-- Thick crescent moon body on the left with even-odd cutout craters -->
        <path
            android:fillColor="#FFFFFFFF"
            android:fillType="evenOdd"
            android:pathData="M 50,10 A 40,40 0 0,0 50,90 A 28,40 0 0,1 50,10 Z M 22,49 A 5,5 0 1,0 21.9,49 Z M 30,32 A 5,5 0 0,0 30,42 A 4,5 0 0,1 30,32 Z M 40,18 A 4,4 0 1,0 39.9,18 Z M 46,15 A 2,2 0 1,0 45.9,15 Z" />
            
    </group>
</vector>
